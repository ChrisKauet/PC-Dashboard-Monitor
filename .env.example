# PC Dashboard Monitor — Backend Config
# Copy this to .env and fill in your values

# HTTP server port
SENSOR_PORT=8080

# Cooldown between sensor reads (seconds)
SENSOR_COOLDOWN=1.0

# Tunnel type: "cloudflare" or "ngrok"
TUNNEL_TYPE=cloudflare

# Tunnel token (optional — for Cloudflare Tunnel token or ngrok authtoken)
TUNNEL_TOKEN=
