# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# Supabase credentials (rotate at: https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY

# How often (seconds) sensor data is pushed to Supabase
PUSH_INTERVAL_SECONDS=5

# Path to LibreHardwareMonitor folder (optional — auto-detected if not set)
# LHM_DIR=C:\Users\YourName\Downloads\LibreHardwareMonitor

# CORS origin for local HTTP API (optional — default * is fine for localhost-only use)
# ALLOWED_ORIGIN=http://localhost:3000

# Dashboard URL opened by the system tray icon
# DASHBOARD_URL=https://pc-dashboard-monitor.vercel.app
